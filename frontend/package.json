{
  "name": "pi-health-frontend-v2",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run check && vite build",
    "preview": "vite preview",
    "check": "tsc --project tsconfig.app.json --noEmit && tsc --project tsconfig.node.json --noEmit",
    "test:capabilities": "node --experimental-strip-types --test tests/capability-renderer.test.ts tests/capability-renderer.ssr.test.mjs",
    "test:extensions": "node --experimental-strip-types tests/extensions.test.ts",
    "test:integration-lifecycle": "node --experimental-strip-types --test tests/integration-lifecycle.test.ts",
    "test:pools": "node --experimental-strip-types --test tests/pools.test.ts",
    "test:protection": "node --experimental-strip-types --test tests/protection.test.ts",
    "test:routes": "node --experimental-strip-types tests/routes.test.ts",
    "test:disks": "node --experimental-strip-types --test tests/disk-summary.test.ts",
    "build:publish": "npm run build && rm -rf ../static/v2 && mkdir -p ../static/v2 && cp -R dist/* ../static/v2/ && python3 ../scripts/bundle_source_digest.py --write"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.515.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "tailwind-merge": "^3.0.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3",
    "vite": "^5.4.11"
  }
}
