# Copy to .env next to compose.yaml and fill in. Do NOT commit the real .env.

# Postgres
POSTGRES_USER=mmuser
POSTGRES_PASSWORD=change-me-long-random
POSTGRES_DB=mattermost

# Mattermost — set to the Pi's LAN address so webhooks/links resolve.
MM_SITE_URL=http://192.168.0.45:8065
# Pin to a specific release for reproducibility (check hub.docker.com/r/mattermost/mattermost-team-edition/tags).
MM_IMAGE_TAG=latest
TZ=Europe/London
