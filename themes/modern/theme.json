{
  "name": "modern",
  "display_name": "Modern",
  "title": "Pi-Health Dashboard",
  "description": "Clean, minimal dark theme inspired by modern UI design",
  "icons": { "style": "minimal", "file": "icons.js" },
  "banner": { "filename": "banner.jpg", "alt_text": "Pi-Health" },

  "colors": {
    "primary": "#3b82f6",
    "primary_light": "#60a5fa",
    "primary_dark": "#2563eb",
    "accent": "#6366f1",
    "accent_light": "#818cf8",
    "background": "#09090b",
    "background_secondary": "#18181b",
    "background_tertiary": "#27272a",
    "text_primary": "#fafafa",
    "text_secondary": "#a1a1aa",
    "text_muted": "#71717a",
    "success": "#22c55e",
    "warning": "#eab308",
    "error": "#ef4444",
    "info": "#3b82f6",
    "border": "#27272a",
    "border_light": "#3f3f46",
    "input_background": "#18181b",
    "ring": "#3b82f6"
  },

  "gradients": {
    "header": "none",
    "button": "none",
    "card_options": ["none", "none", "none", "none", "none", "none"]
  },

  "effects": {
    "card_glow": "none",
    "card_hover_glow": "0 1px 3px rgba(0, 0, 0, 0.4)",
    "text_shadow": "none",
    "card_border_radius": "0.5rem",
    "button_border_radius": "0.375rem",
    "transition_speed": "150ms"
  },

  "typography": {
    "font_family": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
    "font_mono": "'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace",
    "heading_weight": "600",
    "body_weight": "400"
  },

  "components": {
    "nav_background": "#09090b",
    "nav_border": "#27272a",
    "nav_link_color": "#a1a1aa",
    "nav_link_hover": "#fafafa",
    "nav_active_bg": "#27272a",
    "nav_active_color": "#fafafa",
    "nav_active_border": "#3b82f6",
    "nav_dropdown_bg": "#18181b",
    "nav_dropdown_border": "#27272a",

    "card_background": "#18181b",
    "card_border": "#27272a",
    "card_hover_border": "#3f3f46",
    "card_header_bg": "#18181b",

    "button_primary_bg": "#3b82f6",
    "button_primary_hover": "#2563eb",
    "button_primary_text": "#ffffff",
    "button_secondary_bg": "#27272a",
    "button_secondary_hover": "#3f3f46",
    "button_secondary_text": "#fafafa",
    "button_danger_bg": "#dc2626",
    "button_danger_hover": "#b91c1c",

    "toggle_off": "#3f3f46",
    "toggle_on": "#3b82f6",

    "progress_bar_bg": "#27272a",
    "progress_bar_fill": "#3b82f6",

    "modal_backdrop": "rgba(0, 0, 0, 0.8)",
    "modal_bg": "#18181b",
    "modal_border": "#27272a",

    "input_border": "#27272a",
    "input_focus_border": "#3b82f6",
    "input_bg": "#09090b",

    "toast_success_bg": "#052e16",
    "toast_success_border": "#22c55e",
    "toast_error_bg": "#450a0a",
    "toast_error_border": "#ef4444",
    "toast_warning_bg": "#422006",
    "toast_warning_border": "#eab308",
    "toast_info_bg": "#172554",
    "toast_info_border": "#3b82f6",

    "code_bg": "#09090b",
    "code_border": "#27272a",

    "loading_spinner_color": "#3b82f6"
  },

  "status_colors": {
    "running": "#22c55e",
    "exited": "#ef4444",
    "paused": "#eab308",
    "restarting": "#3b82f6",
    "created": "#6366f1",
    "removing": "#f97316",
    "dead": "#991b1b"
  }
}
