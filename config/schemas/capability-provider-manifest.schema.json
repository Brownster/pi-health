{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://limeos.local/schemas/capability-provider-manifest-v1.json",
  "title": "LimeOS capability provider manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "id",
    "name",
    "description",
    "version",
    "runtime",
    "compatibility",
    "capabilities"
  ],
  "properties": {
    "manifest_version": {"const": "1"},
    "id": {"$ref": "#/definitions/id"},
    "name": {"type": "string", "minLength": 1, "maxLength": 80},
    "description": {"type": "string", "maxLength": 240},
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][0-9A-Za-z.-]+)?$",
      "maxLength": 64
    },
    "runtime": {"$ref": "#/definitions/runtime"},
    "compatibility": {"$ref": "#/definitions/compatibility"},
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "uniqueItems": true,
      "items": {"$ref": "#/definitions/capability"}
    }
  },
  "definitions": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$",
      "maxLength": 64
    },
    "capabilityId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:\\.[a-z][a-z0-9_-]*)+$",
      "maxLength": 96
    },
    "schemaId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)*-v[1-9][0-9]*$",
      "maxLength": 96
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {"enum": ["builtin-python", "github-python", "integration-adapter"]},
        "entry": {
          "type": "string",
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9_./-]+\\.py$",
          "maxLength": 160
        },
        "class": {
          "type": "string",
          "pattern": "^[A-Z][A-Za-z0-9_]*$",
          "maxLength": 96
        }
      },
      "allOf": [
        {
          "if": {"properties": {"kind": {"enum": ["builtin-python", "github-python"]}}},
          "then": {"required": ["entry", "class"]}
        },
        {
          "if": {"properties": {"kind": {"const": "integration-adapter"}}},
          "then": {
            "not": {"anyOf": [{"required": ["entry"]}, {"required": ["class"]}]}
          }
        }
      ]
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["capability_api"],
      "properties": {
        "capability_api": {"const": "1"},
        "limeos_min": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
          "maxLength": 32
        },
        "limeos_max": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
          "maxLength": 32
        }
      }
    },
    "contractReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contract_version", "schema_id"],
      "properties": {
        "contract_version": {"const": "1"},
        "schema_id": {"$ref": "#/definitions/schemaId"}
      }
    },
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "surface",
        "renderer",
        "permissions",
        "setup",
        "status",
        "actions"
      ],
      "properties": {
        "id": {"$ref": "#/definitions/capabilityId"},
        "surface": {
          "enum": ["pools", "protection", "mounts", "shares", "integrations", "other"]
        },
        "renderer": {"$ref": "capability-provider-renderer-v1.json"},
        "permissions": {"$ref": "capability-provider-permissions-v1.json"},
        "setup": {"$ref": "#/definitions/contractReference"},
        "status": {"$ref": "#/definitions/contractReference"},
        "actions": {
          "type": "array",
          "maxItems": 32,
          "items": {
            "$ref": "capability-provider-actions-v1.json#/definitions/actionDeclaration"
          }
        }
      }
    }
  }
}
