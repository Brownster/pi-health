{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LimeOS package baseline manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "packages"],
  "properties": {
    "schema_version": {"const": "1"},
    "packages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "manager", "policy"],
        "properties": {
          "name": {"type": "string", "pattern": "^[a-z0-9][a-z0-9+._-]{0,127}$"},
          "manager": {"enum": ["apt", "pip", "npm", "claude"]},
          "policy": {"enum": ["pinned", "present-min", "present", "absent"]},
          "version": {"type": "string", "pattern": "^[0-9][0-9A-Za-z.:+~-]{0,63}$"},
          "critical": {"type": "boolean"},
          "disable_self_update": {"type": "boolean"}
        },
        "allOf": [
          {
            "if": {"properties": {"policy": {"enum": ["pinned", "present-min"]}}},
            "then": {"required": ["version"]}
          },
          {
            "if": {"properties": {"policy": {"enum": ["present", "absent"]}}},
            "then": {"not": {"required": ["version"]}}
          }
        ]
      }
    }
  }
}
